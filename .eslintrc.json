{
  "root": true,
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "globals": {
    "h": "readonly",
    "Fragment": "readonly"
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prefer-const": "warn",
    "no-var": "error",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-unused-vars": ["error", { "varsIgnorePattern": "^(App|TimerCard|ConfigSliders|InstallBanner|Footer)$", "argsIgnorePattern": "^_" }]
  }
}
